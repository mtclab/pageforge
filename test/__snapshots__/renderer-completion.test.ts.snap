</section>
</main>
<footer>
<p>Sivut: Mikoshi</p>
</footer>
<script>
document.querySelectorAll('[data-email-a][data-email-b]').forEach(function (link) {
  link.addEventListener('click', function (event) {
    event.preventDefault();
    window.location.href = link.dataset.emailA + link.dataset.emailB;
  });
});
</script>
</div>
</body>
</html>
